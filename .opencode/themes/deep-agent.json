{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black": "#060607",
    "panel": "#141414",
    "input": "#202020",
    "muted": "#8A8A8A",
    "text": "#F3F4F6",
    "blue": "#4FA3FF",
    "green": "#44BA81",
    "orange": "#E67E22",
    "red": "#FF5F57"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "green",
      "light": "green"
    },
    "accent": {
      "dark": "blue",
      "light": "blue"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "text",
      "light": "black"
    },
    "textMuted": {
      "dark": "muted",
      "light": "muted"
    },
    "background": {
      "dark": "black",
      "light": "#FFFFFF"
    },
    "backgroundPanel": {
      "dark": "panel",
      "light": "#F3F4F6"
    },
    "backgroundElement": {
      "dark": "input",
      "light": "#E5E7EB"
    },
    "border": {
      "dark": "#303448",
      "light": "#D1D5DB"
    },
    "borderActive": {
      "dark": "blue",
      "light": "blue"
    },
    "borderSubtle": {
      "dark": "#252525",
      "light": "#E5E7EB"
    }
  }
}
